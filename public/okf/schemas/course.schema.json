{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://glaucodeveloper.github.io/cognoscere/okf/schemas/course.schema.json",
  "title": "Lumira Public Course",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "format",
    "publicContractVersion",
    "legacyOkfStatus",
    "id",
    "title",
    "subtitle",
    "area",
    "stage",
    "grade",
    "progress",
    "skillRefs",
    "promptRefs",
    "cycles",
    "traceability"
  ],
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "format": { "const": "lumira-okf-public-course" },
    "publicContractVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "legacyOkfStatus": { "const": "reconstructed-from-remnants" },
    "id": { "$ref": "#/$defs/id" },
    "title": { "type": "string", "minLength": 1 },
    "subtitle": { "type": "string", "minLength": 1 },
    "area": { "type": "string", "minLength": 1 },
    "stage": { "type": "string", "minLength": 1 },
    "grade": { "type": "string", "minLength": 1 },
    "progress": { "type": "integer", "minimum": 0, "maximum": 100 },
    "skillRefs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/relativeJsonPath" }
    },
    "promptRefs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/relativeJsonPath" }
    },
    "cycles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "status", "axes"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "title": { "type": "string", "minLength": 1 },
          "status": { "$ref": "#/$defs/learningStatus" },
          "axes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "title", "summary", "status", "duration", "materialPath", "activityPath"],
              "properties": {
                "id": { "$ref": "#/$defs/id" },
                "title": { "type": "string", "minLength": 1 },
                "summary": { "type": "string", "minLength": 1 },
                "status": { "$ref": "#/$defs/learningStatus" },
                "duration": { "type": "string", "minLength": 1 },
                "materialPath": { "$ref": "#/$defs/relativeJsonPath" },
                "activityPath": { "$ref": "#/$defs/relativeJsonPath" }
              }
            }
          }
        }
      }
    },
    "traceability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skillCodes", "canonicalLevels", "source", "status", "sources", "contentStatus", "notes"],
      "properties": {
        "skillCodes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^EF[0-9]{2}[A-Z]{2}[0-9]{2}$" }
        },
        "canonicalLevels": { "$ref": "#/$defs/canonicalLevels" },
        "source": { "type": "string", "minLength": 1 },
        "status": { "const": "legacy-needs-review" },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["repositoryPath", "role"],
            "properties": {
              "repositoryPath": { "type": "string", "minLength": 1 },
              "commit": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
              "role": { "type": "string", "minLength": 1 }
            }
          }
        },
        "contentStatus": { "const": "legacy-needs-review" },
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "relativeJsonPath": {
      "type": "string",
      "pattern": "^(?!/|[a-zA-Z][a-zA-Z0-9+.-]*://)(?!.*\\.\\.)[^?#]+\\.json$"
    },
    "learningStatus": { "enum": ["locked", "available", "current", "in-progress", "completed", "needs-review"] },
    "canonicalLevels": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "prefixItems": [
        { "const": "Iniciação" },
        { "const": "Apropriação" },
        { "const": "Consolidação" },
        { "const": "Proficiência" },
        { "const": "Domínio" }
      ],
      "items": false
    }
  }
}
