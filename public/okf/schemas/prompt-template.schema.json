{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://glaucodeveloper.github.io/cognoscere/okf/schemas/prompt-template.schema.json",
  "title": "Lumira OKF Public Prompt Contract",
  "description": "Public metadata for a prompt capability. Complete prompt bodies and private scoring instructions are intentionally excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "format",
    "publicContractVersion",
    "legacyOkfStatus",
    "id",
    "title",
    "capability",
    "visibility",
    "templateExposure",
    "promptBodyPublished",
    "purpose",
    "inputs",
    "outputs",
    "guardrails",
    "humanOversight",
    "provenance"
  ],
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "format": { "const": "lumira-okf-public-prompt-contract" },
    "publicContractVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "legacyOkfStatus": { "const": "reconstructed-from-remnants" },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 1 },
    "capability": { "enum": ["generation", "analysis", "rewrite-audit"] },
    "visibility": { "const": "public-contract" },
    "templateExposure": { "const": "metadata-only" },
    "promptBodyPublished": { "const": false },
    "purpose": { "type": "string", "minLength": 1 },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/field" }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/field" }
    },
    "guardrails": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "humanOversight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "role", "progressionEffect"],
      "properties": {
        "required": { "const": true },
        "role": { "type": "string", "minLength": 1 },
        "progressionEffect": { "const": "none-until-reviewed" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["legacyOkfStatus", "derivedFrom", "excludedInternalContent"],
      "properties": {
        "legacyOkfStatus": { "const": "reconstructed-from-remnants" },
        "derivedFrom": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["repositoryPath", "role"],
            "properties": {
              "repositoryPath": { "type": "string", "minLength": 1 },
              "commit": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
              "role": { "type": "string", "minLength": 1 }
            }
          }
        },
        "excludedInternalContent": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "sensitivity"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9]*$" },
        "description": { "type": "string", "minLength": 1 },
        "sensitivity": { "enum": ["public", "minimized-personal-data", "internal"] }
      }
    }
  }
}
