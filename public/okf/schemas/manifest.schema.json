{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://glaucodeveloper.github.io/cognoscere/okf/schemas/manifest.schema.json",
  "title": "Cognoscere OKF Public Projection Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "format",
    "publicContractVersion",
    "generatedAt",
    "legacyOkfStatus",
    "reconstructionSources",
    "schemas",
    "skills",
    "promptTemplates",
    "courses"
  ],
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "format": { "const": "cognoscere-okf-manifest" },
    "publicContractVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "legacyOkfStatus": { "const": "reconstructed-from-remnants" },
    "reconstructionSources": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["repositoryPath", "role"],
        "properties": {
          "repositoryPath": { "type": "string", "minLength": 1 },
          "commit": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
          "role": { "type": "string", "minLength": 1 }
        }
      }
    },
    "schemas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest", "course", "publicSkill", "material", "promptTemplate", "analysisResult"],
      "properties": {
        "manifest": { "$ref": "#/$defs/relativeJsonPath" },
        "course": { "$ref": "#/$defs/relativeJsonPath" },
        "publicSkill": { "$ref": "#/$defs/relativeJsonPath" },
        "material": { "$ref": "#/$defs/relativeJsonPath" },
        "promptTemplate": { "$ref": "#/$defs/relativeJsonPath" },
        "analysisResult": { "$ref": "#/$defs/relativeJsonPath" }
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/indexEntry" }
    },
    "promptTemplates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/indexEntry" }
    },
    "courses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "path", "status"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "title": { "type": "string", "minLength": 1 },
          "path": { "$ref": "#/$defs/relativeJsonPath" },
          "status": { "enum": ["draft", "preview", "active", "needs-review", "archived"] }
        }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "relativeJsonPath": {
      "type": "string",
      "pattern": "^(?!/|[a-zA-Z][a-zA-Z0-9+.-]*://)(?!.*\\.\\.)[^?#]+\\.json$"
    },
    "indexEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "path", "status"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "code": { "type": "string", "pattern": "^EF[0-9]{2}[A-Z]{2}[0-9]{2}$" },
        "title": { "type": "string", "minLength": 1 },
        "path": { "$ref": "#/$defs/relativeJsonPath" },
        "status": { "enum": ["draft", "preview", "active", "needs-review", "archived"] }
      }
    }
  }
}
